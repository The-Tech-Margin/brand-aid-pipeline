{
  "name": "brand-helper",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "@thetechmargin <sonia@thetechmargin.com>",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:gen": "tsx scripts/gen-docs.ts",
    "docs:check": "tsx scripts/gen-docs.ts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline:run": "tsx scripts/pipeline-run.ts",
    "seed": "tsx scripts/seed-assets.ts",
    "db:types": "supabase gen types typescript --project-id \"${SUPABASE_PROJECT_ID:?set SUPABASE_PROJECT_ID, e.g. SUPABASE_PROJECT_ID=xxxx npm run db:types}\" --schema brand_helper > src/types/database.ts.tmp && mv src/types/database.ts.tmp src/types/database.ts || rm -f src/types/database.ts.tmp",
    "sbom": "cyclonedx-npm --ignore-npm-errors --output-reproducible --output-file sbom.json"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "ai": "^6.0.205",
    "archiver": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "konva": "^10.3.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-konva": "^19.2.5",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^8.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
