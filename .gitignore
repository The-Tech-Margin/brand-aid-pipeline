# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template IS committed (no secrets in it).
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build-spec archive (kept local, not part of the repo)
*.zip

# local editor/agent settings
.claude/settings.local.json

# generated docs are committed; their build cache is not
.docs-cache/

# CLI run reports (local artifacts)
/reports/

# editors / IDEs
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# OS cruft
Thumbs.db
ehthumbs.db
Desktop.ini

# tooling caches / logs
.turbo/
.eslintcache
*.log
*.tmp
