{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/prohibited-terms.schema.json",
  "title": "Prohibited Terms Lexicon",
  "description": "Configurable legal/compliance lexicon scanned against campaign messages and generated copy.",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "locale_scope": { "type": "string" },
    "notes": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "match", "severity", "reason"],
        "additionalProperties": false,
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "match": {
            "type": "string",
            "enum": ["word", "phrase", "substring"],
            "description": "word = whole-word boundary; phrase = multi-word; substring = raw contains. All case-insensitive."
          },
          "severity": {
            "type": "string",
            "enum": ["fail", "warn", "info"]
          },
          "category": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
