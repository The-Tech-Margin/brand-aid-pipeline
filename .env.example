# Brand Helper — environment template. Copy to .env.local and fill in.
# Never commit real secrets. In production these are served from Vercel env vars.

# --- Supabase (shared portfolio backend) ---
# URL + anon key are safe to expose to the browser; the service role key is SERVER-ONLY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres schema this app owns inside the shared project.
SUPABASE_DB_SCHEMA=brand_helper

# Storage bucket for generated creatives + seeded input assets.
SUPABASE_STORAGE_BUCKET=brand-helper

# Your Supabase project ref (the subdomain in NEXT_PUBLIC_SUPABASE_URL), used only
# by `npm run db:types` to regenerate database types. Export it in your shell when
# running that script: `SUPABASE_PROJECT_ID=xxxx npm run db:types`.
SUPABASE_PROJECT_ID=

# --- Vercel AI Gateway (image generation + in-editor edits) ---
# Single server-only key routes the OpenAI / Google / Black Forest Labs (FLUX) image
# models selected per-campaign in the brief. Used for hero generation and the in-app
# editor's AI ops (remove background, generative replace). Create one at
# https://vercel.com/<team>/~/ai/api-keys.
AI_GATEWAY_API_KEY=

# --- Feature flags ---
# Sound is forward-looking scaffolding only — keep disabled.
SOUND_ENABLED=false

# --- App ---
NEXT_PUBLIC_APP_NAME=Brand Helper

# Canonical public base URL — used to build auth email redirect links (see
# src/lib/get-url.ts). Set this to your production domain in Vercel, e.g.
# https://your-app.example.com, and add it to Supabase's Auth Redirect URLs
# allowlist. Leave blank locally (falls back to http://localhost:3000). Vercel
# also auto-provides NEXT_PUBLIC_VERCEL_URL per deployment, used as a fallback
# when NEXT_PUBLIC_SITE_URL is unset.
NEXT_PUBLIC_SITE_URL=

# Extra origins this app also answers to (besides NEXT_PUBLIC_SITE_URL, the Vercel
# deploy URL, and localhost), used to validate where auth links may land. Optional,
# comma-separated, e.g. https://www.your-app.example.com,https://your-app.vercel.app
NEXT_PUBLIC_APP_ORIGINS=

# --- Access control (invite-only) ---
# Admins are defined in the DB, not here: add an email to brand_helper.admin_allowlist
# (a trigger stamps members.role from it — see migration 0006). Disable public
# sign-ups in Supabase (Auth > Providers > Email) so access stays invite-only.

# --- Access-request notifications (Resend) ---
# Optional: when RESEND_API_KEY is unset the email layer no-ops (requests still store),
# so dev/preview/CI run without it. RESEND_FROM must be a verified Resend sender.
# REQUEST_NOTIFY_EMAIL is where new-request notifications are sent (defaults to owner).
RESEND_API_KEY=
RESEND_FROM=
REQUEST_NOTIFY_EMAIL=

# --- Local development only ---
# Email used by GET /auth/dev-login, which mints a session without the magic-link
# email so the local preview can reach gated pages. The route is hard-blocked in
# production (NODE_ENV guard + proxy). The user must already exist in Supabase Auth.
# Defaults to the seeded owner if unset.
DEV_LOGIN_EMAIL=

# --- CLI (headless pipeline runs) ---
# RLS requires every run to be owned by a real auth user. Set this to a seeded
# user's UUID so `npm run pipeline:run` can write as that owner.
PIPELINE_RUN_USER_ID=
